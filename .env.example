VITE_BIOSENSESIGNAL_LICENSE_KEY=
VITE_BIOSENSESIGNAL_PRODUCT_ID=

# Дев-бекенд (базовый URL для API)
VITE_API_BASE_URL=https://dev-backend.scan.mobilemed.ai

# Опционально: Bearer для POST /auth/login (если бекенд требует по OpenAPI)
# VITE_API_AUTH_BEARER=

# UTM для тела login (или query ?utm= в URL страницы)
# VITE_AUTH_UTM=

# Отладка: повторный auth/login — http://localhost:5173/?reauth=1 (сбросит mm_api_* в sessionStorage)
